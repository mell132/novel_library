---
// src/pages/search.astro
// 引入 Pagefind 的 CSS 和 JS（构建后会自动生成在 /pagefind/ 下）
const pagefindStyles = '/pagefind/pagefind-ui.css';
const pagefindScript = '/pagefind/pagefind-ui.js';
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>搜索小说</title>
  <link rel="stylesheet" href={pagefindStyles}>
  <style>
    body {
      max-width: 900px;
      margin: 2rem auto;
      padding: 0 1rem;
      font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    }
    h1 {
      font-size: 2rem;
      margin-bottom: 1rem;
    }
    #search {
      margin: 2rem 0;
    }
    .back-link {
      display: inline-block;
      margin-top: 2rem;
      color: #0066cc;
      text-decoration: none;
    }
  </style>
</head>
<body>
  <h1>🔍 搜索小说</h1>
  <div id="search"></div>
  <a href="/" class="back-link">← 返回小说列表</a>

  <script type="module">
    import { PagefindUI } from '/pagefind/pagefind-ui.js';
    
    new PagefindUI({
      element: "#search",
      showImages: false,
      showSubResults: false,
      resetStyles: false
    });
  </script>
</body>
</html>