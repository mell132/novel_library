---
// src/pages/search.astro
const pagefindStyles = '/pagefind/pagefind-ui.css';
const pagefindScript = '/pagefind/pagefind-ui.js';
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>搜索小说</title>
  <link rel="stylesheet" href={pagefindStyles}>
  <style>
    body {
      max-width: 800px;
      margin: 2rem auto;
      padding: 0 1rem;
      font-family: system-ui, sans-serif;
    }
    #search {
      margin: 2rem 0;
    }
    /* 确保搜索结果样式正常 */
    .pagefind-ui__results {
      margin-top: 1rem;
    }
  </style>
</head>
<body>
  <h1>🔍 搜索小说</h1>
  <div id="search"></div>
  <a href="/">← 返回列表</a>

  <script src={pagefindScript}></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      if (typeof PagefindUI !== 'undefined') {
        new PagefindUI({
          element: "#search",
          showImages: false,        // 小说没有图片
          showSubResults: false,    // 不需要子结果
          resetStyles: false,       // 保留基础样式
          // 确保搜索结果默认显示（以下选项可省略，默认即为 true）
          showResults: true,
          autofocus: true
        });
      } else {
        console.error('PagefindUI 加载失败');
      }
    });
  </script>
</body>
</html>