---
// src/pages/novels/[...slug].astro
// 获取所有 .txt 文件
const txtFiles = import.meta.glob('../../novels/*.txt', { as: 'raw', eager: true });

export function getStaticPaths() {
  return Object.keys(txtFiles).map((filePath) => {
    const fileName = filePath.split('/').pop().replace('.txt', '');
    return {
      params: { slug: fileName },
      props: { content: txtFiles[filePath] },
    };
  });
}

const { content } = Astro.props;
const title = Astro.params.slug;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} - 小说库</title>
  <style>
    body { max-width: 800px; margin: 2rem auto; padding: 0 1rem; font-family: system-ui, sans-serif; line-height: 1.6; }
    h1 { border-bottom: 2px solid #e0e0e0; padding-bottom: 0.5rem; }
    pre { white-space: pre-wrap; word-wrap: break-word; background: #f5f5f5; padding: 1rem; border-radius: 8px; }
  </style>
</head>
<body>
  <h1 data-pagefind-weight="10">{title}</h1>
  <pre>{content}</pre>
  <a href="/">← 返回列表</a>
</body>
</html>